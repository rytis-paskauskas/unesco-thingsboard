      "singletonMode" : false,
      "type" : "org.thingsboard.rule.engine.profile.TbDeviceProfileNode"
    }, {
      "additionalInfo" : {
        "description" : "Author: Rytis Paskauskas. This is a new implementation of bit reader. I think this should be useful for all Barani design instances. It should be robust by converting to 0 and 1 list.\nTranscribed to TBEL from https://github.com/Milesight-IoT/SensorDecoders/blob/main/ft-series/ft101/ft101-decoder.js\n",
        "layoutX" : 1028,
        "layoutY" : 251
      },
      "configuration" : {
        "scriptLang" : "TBEL",
        "jsScript" : "var decoded = {};\nvar b64 = msg.data;\n\n// Base64 → binary string\nvar binaryStr = atob(b64);\n\n// Binary string → byte array\nvar bytes = new Uint8Array(binaryStr.length);\nfor (var i = 0; i < binaryStr.length; i++) {\n    bytes[i] = binaryStr.charCodeAt(i) & 0xFF;\n}\n\ndecoded.bytes= bytes;\n\n\nreturn {msg: decoded, metadata: metadata, msgType: msgType};",
        "tbelScript" : "// Example:\n// {\"frmPayload\":\"+4BRsgCQ\", \"fPort\": 1, \"fCnt\": 257}\n// {\"frmPayload\": \"/IBX/gCQ\",\"fPort\": 1,\"fCnt\": 258}\n\n\n// Utilities by Rytis 2026-04-02\n\nfunction round0(x) {\n    if (x == null) {\n        return null;\n    }\n    return Math.round(x);\n}\n\nfunction round1(x) {\n    if (x == null) {\n        return null;\n    }\n    return Math.round(x * 10.0) / 10.0;\n}\n\nfunction round2(x) {\n    if (x == null) {\n        return null;\n    }\n    return Math.round(x * 100.0) / 100.0;\n}\n\nfunction error_msg(text) {\n    return {\n        msg: {\n            error: text,\n            raw: msg.frmPayload,\n            fCnt: msg.fCnt\n        },\n        metadata: metadata != null ? metadata : {},\n        msgType: msgType != null ? msgType : \"POST_TELEMETRY_REQUEST\"\n    };\n}\n\nfunction bytesToBits(bytes) {\n    var bits = [];\n\n    for (var i = 0; i < bytes.length; i++) {\n        var b = bytes[i];\n\n        // normalize signed → unsigned\n        if (b < 0) {\n            b += 256;\n        }\n\n        // extract bits (MSB → LSB)\n        for (var j = 7; j >= 0; j--) {\n            bits.push((b >> j) & 1);\n        }\n    }\n\n    return bits;\n}\n// Base64 to bits.\nfunction newBitReader(b64) {\n    if (b64 == null) {\n        return null;\n    }\n\n    var raw = base64ToBytesList(b64);\n    var bytes = [];\n    for (var i = 0; i < raw.length; i++) {\n        var b = raw[i];\n        if (b < 0) {\n            b = b + 256;\n        }\n        bytes.push(b);\n    }\n\n    if (bytes.length == 0) {\n        return null;\n    }\n    var bits = bytesToBits(bytes);\n\n    return {\n        repr: bits,\n        pos: 0\n    };\n}\n\nfunction readBits(br, N) {\n    if (br == null) {\n        return null;\n    }\n\n    if (br.repr == null) {\n        return null;\n    }\n\n    if (br.pos == null) {\n        return null;\n    }\n\n    if (N == null || N <= 0) {\n        return 0;\n    }\n\n    var len = br.repr.length;\n\n    if (br.pos + N > len) {\n        return null;\n    }\n\n    var value = 0;\n    var i = 0;\n\n    while (i < N) {\n        var idx = br.pos;\n\n        // safe index check (TBEL defensive)\n        if (idx < 0 || idx >= len) {\n            return null;\n        }\n\n        var bit = br.repr[idx];\n\n        // ensure valid bit\n        if (bit == null) {\n            return null;\n        }\n\n        if (bit != 0 && bit != 1) {\n            return null;\n        }\n\n        // accumulate (MSB-first)\n        value = (value * 2) + bit;\n\n        // advance position\n        br.pos = br.pos + 1;\n        i = i + 1;\n    }\n\n    return value;\n}\n\n\nvar br = newBitReader(msg.frmPayload);\n\nif (br == null) {\n    return error_msg(\"invalid_payload\");\n}\n\nvar index = readBits(br, 8);\nif (index == null) return error_msg(\"payload_too_short:index\");\n\n// var battery_bit = readBits(br, 1);\n// if (battery_bit == null) return error_msg(\"payload_too_short:battery\");\n\nvar battery = null;\nvar bbit = readBits(br, 1);\nif (bbit == 1) {\n    battery = round1(3.3 + 0.2*(index % 5));\n}\n\nvar rc = readBits(br, 12);\nif (rc == null) return error_msg(\"payload_too_short:rc\");\n\nvar tt = readBits(br, 10);\nif (tt == null) return error_msg(\"payload_too_short:tt\");\n\nvar rcc = readBits(br, 12);\nif (rcc == null) return error_msg(\"payload_too_short:rcc\");\n\nvar tmp = readBits(br, 1);\nif (tmp == null) return error_msg(\"payload_too_short:tmp\");\n\nvar dbg = readBits(br, 1);\nif (dbg == null) return error_msg(\"payload_too_short:dbg\");\n\nvar t_btw = null;\nif (tt>0 && tt<1023) {\n    var _t = 728.0 / tt;\n    t_btw = round2(_t * _t);\n}\n\n\nvar pld = {\n    rain_indx: index,\n    rain_battery: battery,\n    rc: rc,\n    rcc: rcc,\n    risec: t_btw\n};\n\nreturn {\n    msg: pld,\n    metadata: metadata != null ? metadata : {},\n    msgType: msgType != null ? msgType : \"POST_TELEMETRY_REQUEST\"\n};"
      },
