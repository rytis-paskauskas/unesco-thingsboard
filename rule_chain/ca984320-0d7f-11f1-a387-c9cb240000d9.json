      "additionalInfo" : {
        "description" : "\nTranscribed to TBEL from https://github.com/Milesight-IoT/SensorDecoders/blob/main/ft-series/ft101/ft101-decoder.js\n",
        "layoutX" : 1027,
        "layoutY" : 179
      },
      "configuration" : {
        "scriptLang" : "TBEL",
        "jsScript" : "var decoded = {};\nvar b64 = msg.data;\n\n// Base64 → binary string\nvar binaryStr = atob(b64);\n\n// Binary string → byte array\nvar bytes = new Uint8Array(binaryStr.length);\nfor (var i = 0; i < binaryStr.length; i++) {\n    bytes[i] = binaryStr.charCodeAt(i) & 0xFF;\n}\n\ndecoded.bytes= bytes;\n\n\nreturn {msg: decoded, metadata: metadata, msgType: msgType};",
        "tbelScript" : "// Example: \n// {\"frmPayload\": \"GAUbIA==\", \"fPort\": 3, \"fCnt\": 256}\n\n\n// Utilities by Rytis 2026-04-02\n\nfunction round0(x) {\n    if (x == null) {\n        return null;\n    }\n    return Math.round(x);\n}\n\nfunction round1(x) {\n    if (x == null) {\n        return null;\n    }\n    return Math.round(x * 10.0) / 10.0;\n}\n\nfunction round2(x) {\n    if (x == null) {\n        return null;\n    }\n    return Math.round(x * 100.0) / 100.0;\n}\n\nfunction error_msg(text) {\n    return {\n        msg: {\n            error: text,\n            raw: msg.frmPayload,\n            fCnt: msg.fCnt\n        },\n        metadata: metadata != null ? metadata : {},\n        msgType: msgType != null ? msgType : \"POST_TELEMETRY_REQUEST\"\n    };\n}\n\nfunction bytesToBits(bytes) {\n    var bits = [];\n\n    for (var i = 0; i < bytes.length; i++) {\n        var b = bytes[i];\n\n        // normalize signed → unsigned\n        if (b < 0) {\n            b += 256;\n        }\n\n        // extract bits (MSB → LSB)\n        for (var j = 7; j >= 0; j--) {\n            bits.push((b >> j) & 1);\n        }\n    }\n\n    return bits;\n}\n// Base64 to bits.\nfunction newBitReader(b64) {\n    if (b64 == null) {\n        return null;\n    }\n\n    var raw = base64ToBytesList(b64);\n    var bytes = [];\n    for (var i = 0; i < raw.length; i++) {\n        var b = raw[i];\n        if (b < 0) {\n            b = b + 256;\n        }\n        bytes.push(b);\n    }\n\n    if (bytes.length == 0) {\n        return null;\n    }\n    var bits = bytesToBits(bytes);\n\n    return {\n        repr: bits,\n        pos: 0\n    };\n}\n\nfunction readBits(br, N) {\n    if (br == null) {\n        return null;\n    }\n\n    if (br.repr == null) {\n        return null;\n    }\n\n    if (br.pos == null) {\n        return null;\n    }\n\n    if (N == null || N <= 0) {\n        return 0;\n    }\n\n    var len = br.repr.length;\n\n    if (br.pos + N > len) {\n        return null;\n    }\n\n    var value = 0;\n    var i = 0;\n\n    while (i < N) {\n        var idx = br.pos;\n\n        // safe index check (TBEL defensive)\n        if (idx < 0 || idx >= len) {\n            return null;\n        }\n\n        var bit = br.repr[idx];\n\n        // ensure valid bit\n        if (bit == null) {\n            return null;\n        }\n\n        if (bit != 0 && bit != 1) {\n            return null;\n        }\n\n        // accumulate (MSB-first)\n        value = (value * 2) + bit;\n\n        // advance position\n        br.pos = br.pos + 1;\n        i = i + 1;\n    }\n\n    return value;\n}\n\n\nvar br = newBitReader(msg.frmPayload);\nvar index = readBits(br,8);\nvar rc = readBits(br, 12); // rain counter\nvar tt = readBits(br, 10);\nvar dbg = readBits(br, 5);\nvar t_btw = null;\nif (tt>0 && tt<1023) {\n    t_btw = (728.0 / tt);\n    t_btw = round2(t_btw*t_btw);\n}\n\nvar pld = {\n    warn_indx: index,\n    rc: rc,\n    risec: t_btw\n};\n\nreturn {\n    msg: pld,\n    metadata: metadata,\n    msgType: msgType\n};"
