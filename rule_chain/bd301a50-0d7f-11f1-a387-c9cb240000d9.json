      "additionalInfo" : {
        "description" : "\nTranscribed to TBEL from https://github.com/Milesight-IoT/SensorDecoders/blob/main/ft-series/ft101/ft101-decoder.js\n",
        "layoutX" : 981,
        "layoutY" : 915
      },
      "configuration" : {
        "scriptLang" : "TBEL",
        "jsScript" : "var decoded = {};\nvar b64 = msg.data;\n\n// Base64 → binary string\nvar binaryStr = atob(b64);\n\n// Binary string → byte array\nvar bytes = new Uint8Array(binaryStr.length);\nfor (var i = 0; i < binaryStr.length; i++) {\n    bytes[i] = binaryStr.charCodeAt(i) & 0xFF;\n}\n\ndecoded.bytes= bytes;\n\n\nreturn {msg: decoded, metadata: metadata, msgType: msgType};",
        "tbelScript" : "// {\"frmPayload\": \"bxeAAqUtgAAAXf8=\", \"fPort\": 1, \"fCnt\": 999}\n\nvar bytes = base64ToBytes(msg.frmPayload);\n\nif (bytes == null || bytes.length < 9) {\n    return {\n        msg: { error: \"Payload too short, need >= 9 bytes, got \" + (bytes == null ? \"null\" : bytes.length) },\n        metadata: metadata,\n        msgType: msgType\n    };\n}\n\n// Read 9 bytes as: A (32 bits) + B (32 bits) + C (8 bits), big-endian\nvar A = parseBytesToInt(bytes, 0, 4, true);\nvar B = parseBytesToInt(bytes, 4, 4, true);\nvar C = parseBytesToInt(bytes, 8, 1, true);\n\n// Convert signed to unsigned ranges using arithmetic only\nif (A < 0) A = A + 4294967296; // 2^32\nif (B < 0) B = B + 4294967296;\nif (C < 0) C = C + 256;        // 2^8\n\nvar bitPos = 0;\n\nfunction pow2(n) {\n    return Math.pow(2, n);\n}\n\n// MSB-first single-bit read from the 72-bit stream\nfunction readBit() {\n    var pos = bitPos;\n    bitPos = bitPos + 1;\n\n    if (pos < 32) {\n        // bit 0 is MSB of A\n        return Math.floor(A / pow2(31 - pos)) % 2;\n    } else if (pos < 64) {\n        var p = pos - 32;\n        return Math.floor(B / pow2(31 - p)) % 2;\n    } else {\n        var q = pos - 64;\n        return Math.floor(C / pow2(7 - q)) % 2;\n    }\n}\n\n// Read N bits (MSB-first) as an integer\nfunction readBits(n) {\n    var v = 0;\n    for (var i = 0; i < n; i++) {\n        v = v * 2 + readBit();\n    }\n    return v;\n}\n\nfunction round0(x) { return Math.round(x); }\nfunction round1(x) { return Math.round(x * 10) / 10.0; }\nfunction round2(x) { return Math.round(x * 100) / 100.0; }\n\n// ---- decode fields (total 72 bits) ----\nvar type = round0(readBits(2));\nvar batt = round1(3.0 + (0.05 * readBits(5)));\nvar t    = round1((0.1 * readBits(11)) - 100);\nvar tm   = round1(t - (0.1 * readBits(6)));\nvar tx   = round1(t + (0.1 * readBits(6)));\nvar h    = round1(0.2 * readBits(9));\nvar p    = round2(500 + (0.05 * readBits(14)));\nvar s    = 2 * readBits(10);\nvar sx   = s + 2 * readBits(9);\n\nreturn {\n    msg: { type: type, batt: batt, t: t, tm: tm, tx: tx, h: h, p: p, s: s, sx: sx },\n    metadata: metadata,\n    msgType: msgType\n};"
